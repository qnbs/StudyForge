#!/usr/bin/env bash
# Optional solo-dev hook: refresh graph snapshot before push.
# Install (manual): cp scripts/git-hooks/pre-push-graphify.sample .git/hooks/pre-push && chmod +x .git/hooks/pre-push
set -euo pipefail
cd "$(git rev-parse --show-toplevel)"
npm run graphify:refresh
git add graphify-out/graph.json graphify-out/GRAPH_REPORT.md
echo "[graphify] Staged latest graph snapshot for this push"
